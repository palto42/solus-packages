From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Silke Hofstra <silke@slxh.eu>
Date: Wed, 9 Aug 2023 17:05:56 +0200
Subject: [PATCH 3/4] Set shim name to 'bootloader'

---
 libfwupdplugin/fu-context.c            | 2 +-
 plugins/uefi-capsule/fu-uefi-bootmgr.c | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/libfwupdplugin/fu-context.c b/libfwupdplugin/fu-context.c
index 795ff4074..332256162 100644
--- a/libfwupdplugin/fu-context.c
+++ b/libfwupdplugin/fu-context.c
@@ -2159,7 +2159,7 @@ fu_context_get_esp_files_for_entry(FuContext *self,
 	g_autofree gchar *dp_filename = NULL;
 	g_autofree gchar *filename = NULL;
 	g_autofree gchar *mount_point = NULL;
-	g_autofree gchar *shim_name = fu_context_build_uefi_basename_for_arch("shim");
+	g_autofree gchar *shim_name = fu_context_build_uefi_basename_for_arch("bootloader");
 	g_autoptr(FuVolumeLocker) volume_locker = NULL;
 	g_autoptr(FuEfiFilePathDevicePath) dp_path = NULL;
 	g_autoptr(FuEfiHardDriveDevicePath) dp_hdd = NULL;
diff --git a/plugins/uefi-capsule/fu-uefi-bootmgr.c b/plugins/uefi-capsule/fu-uefi-bootmgr.c
index 4e96a0b70..4ce1ad8e9 100644
--- a/plugins/uefi-capsule/fu-uefi-bootmgr.c
+++ b/plugins/uefi-capsule/fu-uefi-bootmgr.c
@@ -382,7 +382,7 @@ fu_uefi_bootmgr_bootnext(FuUefiCapsuleDevice *capsule_device,
 		g_autofree gchar *shim_basename = NULL;
 		g_autofree gchar *shim_src = NULL;
 
-		shim_basename = fu_uefi_capsule_build_app_basename(pstore, "shim", error);
+		shim_basename = fu_uefi_capsule_build_app_basename(pstore, "bootloader", error);
 		if (shim_basename == NULL)
 			return FALSE;
 		shim_dst = fu_uefi_capsule_device_build_efi_path(capsule_device,
