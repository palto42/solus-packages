From cb2509cb612cf9111a12a7960afd10b0c9d2dede Mon Sep 17 00:00:00 2001
From: William Martin <williammartin@github.com>
Date: Wed, 22 Apr 2026 14:09:27 +0200
Subject: [PATCH] Add build flag for no telemetry

---
 internal/config/config.go             |  2 +-
 internal/config/telemetry_disabled.go | 13 +++++++++++++
 internal/config/telemetry_enabled.go  | 10 ++++++++++
 script/build.go                       |  3 +++
 4 files changed, 27 insertions(+), 1 deletion(-)
 create mode 100644 internal/config/telemetry_disabled.go
 create mode 100644 internal/config/telemetry_enabled.go

diff --git a/internal/config/config.go b/internal/config/config.go
index a694ca65461..8f2513cde54 100644
--- a/internal/config/config.go
+++ b/internal/config/config.go
@@ -691,7 +691,7 @@ var Options = []ConfigOption{
 	{
 		Key:           telemetryKey,
 		Description:   "whether telemetry is enabled, disabled, or logging",
-		DefaultValue:  "enabled",
+		DefaultValue:  defaultTelemetryState,
 		AllowedValues: []string{"enabled", "disabled", "log"},
 		CurrentValue: func(c gh.Config, hostname string) string {
 			return c.Telemetry().Value
diff --git a/internal/config/telemetry_disabled.go b/internal/config/telemetry_disabled.go
new file mode 100644
index 00000000000..7300f072097
--- /dev/null
+++ b/internal/config/telemetry_disabled.go
@@ -0,0 +1,13 @@
+//go:build notelemetry
+
+package config
+
+// defaultTelemetryState controls whether telemetry is enabled or disabled by
+// default. The "notelemetry" build tag makes telemetry disabled by default,
+// but users can still opt in via:
+//
+//	gh config set telemetry enabled
+//
+// or by setting the GH_TELEMETRY environment variable.
+// See internal/config/telemetry_enabled.go and script/build.go.
+var defaultTelemetryState = "disabled"
diff --git a/internal/config/telemetry_enabled.go b/internal/config/telemetry_enabled.go
new file mode 100644
index 00000000000..35732ddb9ee
--- /dev/null
+++ b/internal/config/telemetry_enabled.go
@@ -0,0 +1,10 @@
+//go:build !notelemetry
+
+package config
+
+// defaultTelemetryState controls whether telemetry is enabled or disabled by
+// default. In standard builds telemetry is enabled. Distribution packagers
+// who wish to ship gh with telemetry disabled by default can build with the
+// "notelemetry" build tag instead.
+// See internal/config/telemetry_disabled.go and script/build.go.
+var defaultTelemetryState = "enabled"
diff --git a/script/build.go b/script/build.go
index 2ea0088af97..47751dce9bf 100644
--- a/script/build.go
+++ b/script/build.go
@@ -12,6 +12,9 @@
 //     - GH_OAUTH_CLIENT_SECRET
 //     - SOURCE_DATE_EPOCH: enables reproducible builds
 //     - GO_LDFLAGS
+//     - GO_BUILDTAGS: comma-separated build tags; known tags include:
+//       - "updateable": enable update notifications (used by Homebrew)
+//       - "notelemetry": telemetry disabled by default (users can still opt in)
 //
 //   manpages:
 //     Builds the man pages under `share/man/man1/`.
