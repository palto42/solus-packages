+func (l *Loader) saveToDisk(rule *Rule) error {
+	l.Lock()
+	defer l.Unlock()
+
+	if configpath.IsDefault(l.Path) {
+		l.Path = configpath.User(configpath.RulesDir)
+	}
+
+	fileName := filepath.Join(l.Path, fmt.Sprintf("%s.json", rule.Name))
+	return l.Save(rule, fileName)
