diff --git a/daemon/configpath/path.go b/daemon/configpath/path.go
new file mode 100644
index 00000000..15e22005
--- /dev/null
+++ b/daemon/configpath/path.go
@@ -0,0 +1,47 @@
+package configpath
+
+import (
+	"os"
+	"path/filepath"
+	"strings"
+)
+
+const (
+	DefaultConfigFile  = "default-config.json"
+	NetworkAliasesFile = "network_aliases.json"
+	SystemFWFile       = "system-fw.json"
+	RulesDir           = "rules"
+)
+
+const (
+	defaultConfigDir = "/usr/share/defaults/etc/opensnitchd/"
+	userConfigDir    = "/etc/opensnitchd/"
+)
+
+// Find returns the location of a configuration from either the user or default config directory.
+func Find(file string) string {
+	path := filepath.Join(userConfigDir, file)
+
+	if !Exists(path) {
+		return filepath.Join(defaultConfigDir, file)
+	}
+
+	return path
+}
+
+// User always returns the user path of a configuration file.
+func User(file string) string {
+	return filepath.Join(userConfigDir, file)
+}
+
+// IsDefault returns true if the given configuration file path is in the default configuration directory.
+func IsDefault(path string) bool {
+	return strings.HasPrefix(path, defaultConfigDir)
+}
+
+// Exists returns true if the given directory exists and is accesible.
+func Exists(path string) bool {
+	_, err := os.Stat(path)
+
+	return err == nil
+}
